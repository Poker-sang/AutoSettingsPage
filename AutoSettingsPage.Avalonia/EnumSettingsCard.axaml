<controls:SettingsCard
    x:Class="AutoSettingsPage.Avalonia.EnumSettingsCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="using:AutoSettingsPage.Avalonia"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:local="using:AutoSettingsPage.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AutoSettingsPage.Models"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type models:IEnumSettingsEntry,
                        x:TypeArguments=x:Object}"
    Description="{Binding Converter={x:Static avalonia:SettingsEntryHelper.DescriptionConverter}}"
    Header="{Binding Header}"
    Tag="{Binding Token}"
    mc:Ignorable="d">
    <controls:SettingsCard.HeaderIcon>
        <fluent:SymbolIcon Symbol="{Binding Icon}" />
    </controls:SettingsCard.HeaderIcon>
    <local:EnumComboBox
        Width="200"
        ItemsSource="{Binding EnumItems}"
        PlaceholderText="{Binding Placeholder}"
        SelectedEnum="{Binding Value, Mode=TwoWay}" />
</controls:SettingsCard>
