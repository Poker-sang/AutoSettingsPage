<controls:SettingsCard
    x:Class="AutoSettingsPage.Avalonia.DoubleSettingsCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="using:AutoSettingsPage.Avalonia"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:local="using:AutoSettingsPage.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AutoSettingsPage.Models"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type models:INumberSettingsEntry,
                        x:TypeArguments=x:Double}"
    Description="{Binding Converter={x:Static avalonia:SettingsEntryHelper.DescriptionConverter}}"
    Header="{Binding Header}"
    Tag="{Binding Token}"
    mc:Ignorable="d">
    <controls:SettingsCard.HeaderIcon>
        <fluent:SymbolIcon Symbol="{Binding Icon}" />
    </controls:SettingsCard.HeaderIcon>
    <NumericUpDown
        MinWidth="200"
        FormatString="F0"
        Increment="{Binding Step, Converter={x:Static local:DoubleDecimalConverter.Instance}}"
        Maximum="{Binding Max, Converter={x:Static local:DoubleDecimalConverter.Instance}}"
        Minimum="{Binding Min, Converter={x:Static local:DoubleDecimalConverter.Instance}}"
        Watermark="{Binding Placeholder}"
        Value="{Binding Value, Mode=TwoWay, Converter={x:Static local:DoubleDecimalConverter.Instance}}" />
</controls:SettingsCard>
