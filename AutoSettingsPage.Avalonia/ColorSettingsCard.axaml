<controls:SettingsCard
    x:Class="AutoSettingsPage.Avalonia.ColorSettingsCard"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonia="using:AutoSettingsPage.Avalonia"
    xmlns:controls="using:CommunityToolkit.Avalonia.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fluent="using:FluentIcons.Avalonia"
    xmlns:local="using:AutoSettingsPage.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AutoSettingsPage.Models"
    xmlns:sys="using:System"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="{x:Type models:ISingleValueSettingsEntry,
                        x:TypeArguments=sys:UInt32}"
    Description="{Binding Converter={x:Static avalonia:SettingsEntryHelper.DescriptionConverter}}"
    Header="{Binding Header}"
    Tag="{Binding Token}"
    mc:Ignorable="d">
    <controls:SettingsCard.HeaderIcon>
        <fluent:SymbolIcon Symbol="{Binding Icon}" />
    </controls:SettingsCard.HeaderIcon>
    <ColorPicker Color="{Binding Value, Mode=TwoWay, Converter={x:Static local:ColorSettingsCard.ColorConverter}}" />
</controls:SettingsCard>
